# Example Environment Configuration
# Copy this file to .env and fill in your actual API keys.
# DO NOT commit your actual .env file to version control.

# The API key for your chosen LLM provider.
# Example: OpenAI, Anthropic, or an API key for a local provider.
LLM_API_KEY=your_llm_api_key_here

# (Optional) If your LLM provider requires a specific base URL.
# LLM_BASE_URL=https://api.openai.com/v1

# The execution environment. Use "development" during testing.
ENVIRONMENT=development
